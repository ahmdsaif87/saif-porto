---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { defaultLanguage, useTranslations, type LanguageCode } from '@/i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { Image } from 'astro:assets';
import errorIllustration from '@/assets/error.webp';
import errorIllustrationDark from '@/assets/error-dark.webp';
import { Home } from 'lucide-react';

const lang =
  (Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
const t = useTranslations(lang, 'notFoundPage');

const pageTitle = t('pageTitle');
const pageDescription = t('message');
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription}>
  <section class="relative text-center py-16 md:py-24 overflow-hidden">
    <div class="decorative-orb w-[400px] h-[400px] -top-40 left-1/4 animate-breathe" aria-hidden="true"></div>
    <div class="decorative-orb w-[300px] h-[300px] -bottom-20 right-1/4 animate-breathe animation-delay-300" aria-hidden="true"></div>

    <div class="relative z-10 container mx-auto px-4 max-w-2xl">
      <h1
        class="text-[8rem] md:text-[12rem] font-extrabold leading-none mb-4 text-primary opacity-20"
        style="font-family: var(--font-heading);"
      >
        404
      </h1>

      <Image
        src={errorIllustration}
        alt="Error illustration - Light Mode"
        class="w-48 h-auto mx-auto mb-8 block dark:hidden -mt-12"
        densities={[1, 1.5, 2]}
        quality="mid"
      />
      <Image
        src={errorIllustrationDark}
        alt="Error illustration - Dark Mode"
        class="w-48 h-auto mx-auto mb-8 hidden dark:block -mt-12"
        densities={[1, 1.5, 2]}
        quality="mid"
      />

      <h2
        class="text-2xl md:text-3xl font-bold mb-4"
        style="font-family: var(--font-heading);"
      >
        {t('title')}
      </h2>

      <p class="text-muted-foreground text-lg mb-8 max-w-md mx-auto leading-relaxed">
        {t('message')}
      </p>

      <a
        href={getRelativeLocaleUrl(lang, '/')}
        class="brutalist-btn"
      >
        <Home className="size-4" />
        {t('homeLink')}
      </a>
    </div>
  </section>
</BaseLayout>
