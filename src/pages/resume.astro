---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="Resume | Ahmad Saif" pageDescription="Ahmad Saif's Resume and Curriculum Vitae">
  <div class="max-w-4xl mx-auto flex flex-col gap-6 mt-4">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <h1 class="text-3xl font-bold tracking-tight">Resume</h1>
      <a 
        href="https://drive.google.com/uc?export=download&id=193Mo3q_qxWrz0KuMXn_aRngBEN0ZkOPi" 
        class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground shadow hover:bg-primary/90 h-10 px-6 py-2"
        download
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
        Download CV (PDF)
      </a>
    </div>

    <div class="w-full bg-card border border-border rounded-lg overflow-hidden shadow-sm h-[80vh] min-h-[600px]">
      <iframe 
        src="https://drive.google.com/file/d/193Mo3q_qxWrz0KuMXn_aRngBEN0ZkOPi/preview"
        class="w-full h-full border-0"
        title="Resume Google Docs"
      ></iframe>
    </div>
  </div>
</BaseLayout>
