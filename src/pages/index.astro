---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { defaultLanguage, useTranslations, type LanguageCode } from '@/i18n/ui';
import {
  PortfolioScreen,
  getTranslatedProjects,
  getTranslatedSkills,
  type TranslatedSkill,
  type TranslatedProject,
} from '@/features/projects';

const lang =
  (Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
const t = useTranslations(lang, 'homePage');
const tContact = useTranslations(lang, 'contactPage');

const pageTitle = t('pageTitle');
const pageDescription = t('pageDescription');

const projects: Array<TranslatedProject> = getTranslatedProjects(lang).slice(0, 3);
const skills: Array<TranslatedSkill> = getTranslatedSkills(lang);

const contactFormTranslations = {
  firstNameLabel: tContact('firstNameLabel'),
  lastNameLabel: tContact('lastNameLabel'),
  emailLabel: tContact('emailLabel'),
  messageLabel: tContact('messageLabel'),
  firstNamePlaceholder: tContact('firstNamePlaceholder'),
  lastNamePlaceholder: tContact('lastNamePlaceholder'),
  emailPlaceholder: tContact('emailPlaceholder'),
  messagePlaceholder: tContact('messagePlaceholder'),
  sendButtonLabel: tContact('sendButtonLabel'),
  toastSuccessMessageSent: tContact('toastSuccessMessageSent'),
  toastErrorFailedToSend: tContact('toastErrorFailedToSend'),
  toastErrorUnexpected: tContact('toastErrorUnexpected'),
  toastErrorDetails: tContact('toastErrorDetails'),
  toastErrorValidationFailed: tContact('toastErrorValidationFailed'),
};

const layoutProps = {
  lang,
  projects,
  skills,
  heroGreeting: t('heroGreeting'),
  heroSubtitlePart1: t('heroSubtitlePart1'),
  heroSubtitlePart2: t('heroSubtitlePart2'),
  heroIntroduction: t('heroIntroduction'),
  heroViewWorkButton: t('heroViewWorkButton'),
  heroContactButton: t('heroContactButton'),
  imageNotAvailable: t('imageNotAvailable'),
  featuredProjectsTitle: t('featuredProjectsTitle'),
  featuredProjectsDescription: t('featuredProjectsDescription'),
  mySkillsTitle: t('mySkillsTitle'),
  mySkillsDescription: t('mySkillsDescription'),
  projectPreviewCtaText: t('projectCardViewProject'),
  aboutMeTitle: t('aboutMeTitle'),
  aboutMeDescription: t('aboutMeDescription'),
  experienceTitle: t('experienceTitle'),
  experiences: t('experiences'),
  educationTitle: t('educationTitle'),
  educations: t('educations'),
  contactFormTitle: tContact('formTitle'),
  contactFormTranslations,
};
---

<BaseLayout pageTitle={pageTitle} pageDescription={pageDescription} isLandingPage={true}>
  <PortfolioScreen {...layoutProps} />
</BaseLayout>
