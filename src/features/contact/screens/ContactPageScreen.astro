---
import type { LanguageCode } from '@/i18n/ui';
import { Mail, MapPin, Clock } from 'lucide-react';

import { ContactForm } from '../components/ContactForm.tsx';
import type { ContactFormTranslations } from '../type';

interface Props {
  lang: LanguageCode;
  mainHeadingTitle: string;
  mainHeadingDescription: string;
  formTitle: string;
  formTranslations: ContactFormTranslations;
}

const {
  lang,
  mainHeadingTitle,
  mainHeadingDescription,
  formTitle,
  formTranslations,
} = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="container mx-auto px-6 max-w-screen-xl">
    <div class="mb-12">
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground mb-4"
        style="font-family: var(--font-heading);"
      >
        Contact
      </p>
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 tracking-tight uppercase"
        style="font-family: var(--font-heading);"
      >
        {mainHeadingTitle}
      </h1>
      <div class="section-divider mt-6 mb-8"></div>
      <p class="text-base text-muted-foreground max-w-2xl leading-relaxed">
        {mainHeadingDescription}
      </p>
    </div>

    <div class="grid md:grid-cols-5 gap-8 max-w-4xl">
      <div class="md:col-span-2 space-y-4">
        <div class="border border-border p-5 hover:border-foreground transition-colors duration-300">
          <div class="flex items-start gap-4">
            <Mail className="size-4 text-muted-foreground flex-shrink-0 mt-0.5" />
            <div>
              <h3 class="text-xs font-semibold mb-1 uppercase tracking-widest" style="font-family: var(--font-heading);">Email</h3>
              <a href="mailto:ahmadsaifpy@gmail.com" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                ahmadsaifpy@gmail.com
              </a>
            </div>
          </div>
        </div>

        <div class="border border-border p-5 hover:border-foreground transition-colors duration-300">
          <div class="flex items-start gap-4">
            <MapPin className="size-4 text-muted-foreground flex-shrink-0 mt-0.5" />
            <div>
              <h3 class="text-xs font-semibold mb-1 uppercase tracking-widest" style="font-family: var(--font-heading);">Location</h3>
              <p class="text-sm text-muted-foreground">Tegal, Indonesia</p>
            </div>
          </div>
        </div>

        <div class="border border-border p-5 hover:border-foreground transition-colors duration-300">
          <div class="flex items-start gap-4">
            <Clock className="size-4 text-muted-foreground flex-shrink-0 mt-0.5" />
            <div>
              <h3 class="text-xs font-semibold mb-1 uppercase tracking-widest" style="font-family: var(--font-heading);">Availability</h3>
              <p class="text-sm text-muted-foreground">Open for opportunities</p>
            </div>
          </div>
        </div>
      </div>

      <div class="md:col-span-3">
        <div class="border border-border p-6 md:p-8">
          <h2
            class="text-lg font-bold mb-6 uppercase tracking-wider"
            style="font-family: var(--font-heading);"
          >
            {formTitle}
          </h2>
          <ContactForm client:load {lang} {formTranslations} />
        </div>
      </div>
    </div>
  </div>
</section>
