---
import type { LanguageCode } from '@/i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { ArrowRight, ArrowDown, Download, Mail, Github, Linkedin, Instagram, Twitter } from 'lucide-react';

import heroImage from '@/assets/user-hero.jpeg';
import { Image } from 'astro:assets';
import type { TranslatedProject, TranslatedSkill } from '../type';

import { ContactForm } from '@/features/contact/components/ContactForm.tsx';
import type { ContactFormTranslations } from '@/features/contact/type';

export type Props = {
  lang: LanguageCode;
  projects: Array<TranslatedProject>;
  skills: Array<TranslatedSkill>;
  heroGreeting: string;
  heroSubtitlePart1: string;
  heroSubtitlePart2: string;
  heroIntroduction: string;
  heroViewWorkButton: string;
  heroContactButton: string;
  imageNotAvailable: string;
  featuredProjectsTitle: string;
  featuredProjectsDescription: string;
  mySkillsTitle: string;
  mySkillsDescription: string;
  projectPreviewCtaText: string;
  aboutMeTitle: string;
  aboutMeDescription: string;
  experienceTitle: string;
  experiences: Array<{
    title: string;
    company: string;
    date: string;
    description: string;
  }>;
  educationTitle: string;
  educations: Array<{
    degree: string;
    school: string;
    date: string;
    description: string;
  }>;
  contactFormTitle: string;
  contactFormTranslations: ContactFormTranslations;
};

const {
  lang,
  projects,
  skills,
  heroGreeting,
  heroSubtitlePart1,
  heroSubtitlePart2,
  heroIntroduction,
  heroViewWorkButton,
  heroContactButton,
  imageNotAvailable,
  featuredProjectsTitle,
  featuredProjectsDescription,
  mySkillsTitle,
  mySkillsDescription,
  projectPreviewCtaText,
  aboutMeTitle,
  aboutMeDescription,
  experienceTitle,
  experiences,
  educationTitle,
  educations,
  contactFormTitle,
  contactFormTranslations,
} = Astro.props;

const allTechnologies = Array.from(
  new Set([
    ...skills.flatMap((skillGroup) => skillGroup.technologies.map((tech) => tech.name)),
    ...projects.flatMap((project) => project.technologiesUsed?.map((tech) => tech.name) || [])
  ])
);

const halfTechIndex = Math.ceil(allTechnologies.length / 2);
const firstLineTechnologies = allTechnologies.slice(0, halfTechIndex);
const secondLineTechnologies = allTechnologies.slice(halfTechIndex);
---

{/* ═══════════════════════════════════════════════════════ */}
{/* ===== HERO SECTION ===== */}
{/* ═══════════════════════════════════════════════════════ */}
<section id="hero" class="relative min-h-[90vh] flex items-center border-b border-border">
  <div class="container mx-auto px-6 max-w-screen-xl py-20 md:py-28">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      {/* Hero Text */}
      <div class="order-2 md:order-1">
        <p
          class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground mb-6 opacity-0 animate-fade-in-up"
          style="font-family: var(--font-heading);"
        >
          {heroSubtitlePart1} · {heroSubtitlePart2}
        </p>

        <h1
          class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[0.95] mb-8 opacity-0 animate-fade-in-up animation-delay-100"
          style="font-family: var(--font-heading);"
        >
          {heroGreeting.toUpperCase()}
        </h1>

        <p
          class="text-base md:text-lg text-muted-foreground mb-10 max-w-md leading-relaxed opacity-0 animate-fade-in-up animation-delay-200"
        >
          {heroIntroduction}
        </p>

        {/* CTA Buttons */}
        <div class="flex flex-wrap gap-4 opacity-0 animate-fade-in-up animation-delay-300">
          <a href="#projects" class="brutalist-btn">
            {heroViewWorkButton}
            <ArrowDown className="size-3.5" />
          </a>
          <a href="#contact" class="brutalist-btn-outline">
            {heroContactButton}
          </a>
        </div>

        {/* Scroll indicator */}
        <div class="hidden md:flex items-center gap-3 mt-16 opacity-0 animate-fade-in-up animation-delay-500">
          <div class="w-8 h-px bg-muted-foreground"></div>
          <span class="text-[10px] uppercase tracking-[0.2em] text-muted-foreground" style="font-family: var(--font-heading);">
            Scroll to explore
          </span>
        </div>
      </div>

      {/* Hero Image */}
      <div class="order-1 md:order-2 flex justify-center md:justify-end opacity-0 animate-fade-in-up animation-delay-200">
        <div class="relative w-72 h-80 md:w-[380px] md:h-[460px] overflow-hidden border border-border">
          <Image
            src={heroImage}
            alt={'Ahmad Saif profile photo'}
            widths={[400, 600, 800]}
            sizes="(max-width: 768px) 288px, 380px"
            quality="85"
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
            style="object-position: center 28%;"
          />
        </div>
      </div>
    </div>
  </div>
</section>

{/* ═══════════════════════════════════════════════════════ */}
{/* ===== SKILLS MARQUEE SECTION ===== */}
{/* ═══════════════════════════════════════════════════════ */}
<section class="border-b border-border py-4 md:py-6 overflow-hidden bg-muted/30 flex flex-col gap-4">
  {/* First Line */}
  <div class="flex whitespace-nowrap animate-marquee-slow w-max pause-on-hover">
    {
      [...Array(2)].map((_, index) => (
        <div class="flex shrink-0 items-center gap-8 md:gap-16 px-4 md:px-8" aria-hidden={index === 1 ? "true" : "false"}>
          {firstLineTechnologies.map(tech => (
            <span class="text-sm md:text-base font-bold uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors duration-300" style="font-family: var(--font-heading);">
              {tech}
            </span>
          ))}
        </div>
      ))
    }
  </div>

  {/* Second Line */}
  <div class="flex whitespace-nowrap animate-marquee-reverse-slow w-max pause-on-hover">
    {
      [...Array(2)].map((_, index) => (
        <div class="flex shrink-0 items-center gap-8 md:gap-16 px-4 md:px-8" aria-hidden={index === 1 ? "true" : "false"}>
          {secondLineTechnologies.map(tech => (
            <span class="text-sm md:text-base font-bold uppercase tracking-widest text-muted-foreground hover:text-foreground transition-colors duration-300" style="font-family: var(--font-heading);">
              {tech}
            </span>
          ))}
        </div>
      ))
    }
  </div>
</section>

{/* ═══════════════════════════════════════════════════════ */}
{/* ===== SELECTED PROJECTS SECTION ===== */}
{/* ═══════════════════════════════════════════════════════ */}
<section id="projects" class="py-20 md:py-28 border-b border-border">
  <div class="container mx-auto px-6 max-w-screen-xl">
    {/* Section Header */}
    <div class="mb-16 scroll-reveal">
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground mb-4"
        style="font-family: var(--font-heading);"
      >
        Portfolio
      </p>
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight"
        style="font-family: var(--font-heading);"
      >
        {featuredProjectsTitle.toUpperCase()}
      </h2>
    </div>

    {/* Asymmetric Project Grid */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {
        projects.map((project: TranslatedProject, index: number) => {
          const projectUrl = getRelativeLocaleUrl(lang, `/projects/${project.slug}`);
          const isLarge = index % 3 === 0;
          return (
            <a
              href={projectUrl}
              class={`project-card group block scroll-reveal ${isLarge ? 'md:col-span-2' : ''}`}
              style={`transition-delay: ${index * 100}ms;`}
            >
              {/* Image */}
              <div class={`overflow-hidden ${isLarge ? 'h-64 md:h-96' : 'h-56 md:h-72'}`}>
                {project.imageUrl ? (
                  <Image
                    src={project.imageUrl}
                    alt={project.imageAltText}
                    class="w-full h-full object-cover"
                    widths={[400, 800, 1200]}
                    sizes={isLarge ? '(max-width: 768px) 100vw, 100vw' : '(max-width: 768px) 100vw, 50vw'}
                    quality="mid"
                  />
                ) : (
                  <div class="w-full h-full bg-muted flex items-center justify-center">
                    <p class="text-muted-foreground text-sm">{imageNotAvailable}</p>
                  </div>
                )}
              </div>

              {/* Card Content */}
              <div class="p-5 md:p-6 flex justify-between items-start gap-4">
                <div>
                  <h3
                    class="text-lg md:text-xl font-bold mb-1 tracking-tight"
                    style="font-family: var(--font-heading);"
                  >
                    {project.title.toUpperCase()}
                  </h3>
                  <p class="text-sm text-muted-foreground line-clamp-2">
                    {project.description}
                  </p>
                </div>
                <div class="flex-shrink-0 mt-1">
                  <ArrowRight className="size-4 text-muted-foreground group-hover:text-foreground group-hover:translate-x-1 transition-all duration-300" />
                </div>
              </div>
            </a>
          );
        })
      }
    </div>

    <div class="mt-16 flex justify-center scroll-reveal">
      <a href={getRelativeLocaleUrl(lang, '/projects')} class="brutalist-btn-outline">
        View All Projects
        <ArrowRight className="size-3.5 ml-2" />
      </a>
    </div>
  </div>
</section>

{/* ═══════════════════════════════════════════════════════ */}
{/* ===== PROFESSIONAL JOURNEY SECTION ===== */}
{/* ═══════════════════════════════════════════════════════ */}
<section id="journey" class="py-20 md:py-28 border-b border-border">
  <div class="container mx-auto px-6 max-w-screen-xl">
    <div class="grid md:grid-cols-2 gap-16 lg:gap-24">
      {/* Experience */}
      <div class="scroll-reveal">
        <p
          class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground mb-4"
          style="font-family: var(--font-heading);"
        >
          Career
        </p>
        <h2
          class="text-2xl md:text-3xl font-bold tracking-tight mb-10"
          style="font-family: var(--font-heading);"
        >
          {experienceTitle.toUpperCase()}
        </h2>

        <div class="space-y-8">
          {
            experiences.map((exp) => (
              <div class="timeline-item">
                <h3
                  class="text-base md:text-lg font-bold tracking-tight mb-1"
                  style="font-family: var(--font-heading);"
                >
                  {exp.title.toUpperCase()}
                </h3>
                <p class="text-xs uppercase tracking-widest text-muted-foreground mb-3" style="font-family: var(--font-heading);">
                  {exp.company} · {exp.date}
                </p>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  {exp.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      {/* Education */}
      <div class="scroll-reveal transition-delay-200">
        <p
          class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground mb-4"
          style="font-family: var(--font-heading);"
        >
          Education
        </p>
        <h2
          class="text-2xl md:text-3xl font-bold tracking-tight mb-10"
          style="font-family: var(--font-heading);"
        >
          {educationTitle.toUpperCase()}
        </h2>

        <div class="space-y-8">
          {
            educations.map((edu) => (
              <div class="timeline-item">
                <h3
                  class="text-base md:text-lg font-bold tracking-tight mb-1"
                  style="font-family: var(--font-heading);"
                >
                  {edu.degree.toUpperCase()}
                </h3>
                <p class="text-xs uppercase tracking-widest text-muted-foreground mb-3" style="font-family: var(--font-heading);">
                  {edu.school} · {edu.date}
                </p>
                <p class="text-sm text-muted-foreground leading-relaxed">
                  {edu.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

{/* ═══════════════════════════════════════════════════════ */}
{/* ===== CURRICULUM VITAE SECTION ===== */}
{/* ═══════════════════════════════════════════════════════ */}
<section id="cv" class="inverted-section py-16 md:py-20 scroll-reveal">
  <div class="container mx-auto px-6 max-w-screen-xl">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
      <div>
        <p
          class="text-xs font-medium uppercase tracking-[0.2em] opacity-60 mb-4"
          style="font-family: var(--font-heading);"
        >
          Download
        </p>
        <h2
          class="text-2xl md:text-3xl lg:text-4xl font-bold tracking-tight"
          style="font-family: var(--font-heading);"
        >
          CURRICULUM VITAE
        </h2>
      </div>
      <a
        href="https://drive.google.com/uc?export=download&id=193Mo3q_qxWrz0KuMXn_aRngBEN0ZkOPi"
        download
        class="brutalist-btn-inverted"
      >
        <Download className="size-4" />
        Download CV
      </a>
    </div>
  </div>
</section>

{/* ═══════════════════════════════════════════════════════ */}
{/* ===== CONTACT SECTION ===== */}
{/* ═══════════════════════════════════════════════════════ */}
<section id="contact" class="py-20 md:py-28">
  <div class="container mx-auto px-6 max-w-screen-xl">
    <div class="grid md:grid-cols-2 gap-16 lg:gap-24">
      {/* Contact Info */}
      <div class="scroll-reveal">
        <p
          class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground mb-4"
          style="font-family: var(--font-heading);"
        >
          Get in Touch
        </p>
        <h2
          class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-8"
          style="font-family: var(--font-heading);"
        >
          LET'S START A<br />CONVERSATION.
        </h2>

        <div class="space-y-5 mb-10">
          <a
            href="mailto:ahmadsaif7456@gmail.com"
            class="flex items-center gap-3 text-sm text-muted-foreground hover:text-foreground transition-colors duration-300 group"
          >
            <Mail className="size-4 flex-shrink-0" />
            <span class="border-b border-transparent group-hover:border-foreground transition-all duration-300">ahmadsaif7456@gmail.com</span>
          </a>
        </div>

        {/* Social Links */}
        <div class="flex gap-4">
          <a
            href="https://www.linkedin.com/in/ahmadsaif-dev"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 border border-border text-muted-foreground hover:text-foreground hover:border-foreground transition-all duration-300"
            aria-label="LinkedIn"
          >
            <Linkedin className="size-4" />
          </a>
          <a
            href="https://github.com/ahmdsaif87"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 border border-border text-muted-foreground hover:text-foreground hover:border-foreground transition-all duration-300"
            aria-label="GitHub"
          >
            <Github className="size-4" />
          </a>
          <a
            href="https://www.instagram.com/ahmdsaif87"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 border border-border text-muted-foreground hover:text-foreground hover:border-foreground transition-all duration-300"
            aria-label="Instagram"
          >
            <Instagram className="size-4" />
          </a>
          <a
            href="https://x.com/ahmdsaif_"
            target="_blank"
            rel="noopener noreferrer"
            class="p-2 border border-border text-muted-foreground hover:text-foreground hover:border-foreground transition-all duration-300"
            aria-label="Twitter"
          >
            <Twitter className="size-4" />
          </a>
        </div>
      </div>

      {/* Contact Form */}
      <div class="scroll-reveal transition-delay-200">
        <div class="border border-border p-6 md:p-8">
          <h3
            class="text-lg font-bold mb-6 uppercase tracking-wider"
            style="font-family: var(--font-heading);"
          >
            {contactFormTitle}
          </h3>
          <ContactForm client:load {lang} formTranslations={contactFormTranslations} />
        </div>
      </div>
    </div>
  </div>
</section>
