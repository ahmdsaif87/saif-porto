---
import { defaultLanguage, useTranslations, type LanguageCode } from '@/i18n/ui';
import { Mail, Instagram, Twitter, Github, Linkedin } from 'lucide-react';

const lang =
  (Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
const tFooter = useTranslations(lang, 'footer');
const tSite = useTranslations(lang, 'site');
---

<footer class="relative mt-auto py-10 z-10">
  {/* Gradient divider */}
  <div class="gradient-divider mb-8 mx-auto max-w-screen-xl"></div>

  <div class="container mx-auto px-6 max-w-screen-xl">
    {/* Social links row */}
    <div class="flex justify-center gap-4 mb-6">
      <a
        href="mailto:ahmadsaif7456@gmail.com"
        class="p-2.5 rounded-lg text-muted-foreground hover:text-foreground transition-all duration-300 hover:bg-muted/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.15)]"
        aria-label="Email"
      >
        <Mail className="size-4" />
      </a>
      <a
        href="https://www.instagram.com/ahmdsaif87"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2.5 rounded-lg text-muted-foreground hover:text-foreground transition-all duration-300 hover:bg-muted/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.15)]"
        aria-label="Instagram"
      >
        <Instagram className="size-4" />
      </a>
      <a
        href="https://x.com/ahmdsaif_"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2.5 rounded-lg text-muted-foreground hover:text-foreground transition-all duration-300 hover:bg-muted/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.15)]"
        aria-label="Twitter"
      >
        <Twitter className="size-4" />
      </a>
      <a
        href="https://github.com/ahmdsaif87"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2.5 rounded-lg text-muted-foreground hover:text-foreground transition-all duration-300 hover:bg-muted/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.15)]"
        aria-label="GitHub"
      >
        <Github className="size-4" />
      </a>
      <a
        href="https://www.linkedin.com/in/ahmadsaif-dev"
        target="_blank"
        rel="noopener noreferrer"
        class="p-2.5 rounded-lg text-muted-foreground hover:text-foreground transition-all duration-300 hover:bg-muted/50 hover:shadow-[0_0_15px_rgba(139,92,246,0.15)]"
        aria-label="LinkedIn"
      >
        <Linkedin className="size-4" />
      </a>
    </div>

    {/* Copyright */}
    <p class="text-center text-sm text-muted-foreground">
      &copy; {new Date().getFullYear()}
      <span class="text-primary font-medium"> {tSite('title')}</span>. {tFooter('rights')}
    </p>
  </div>
</footer>
