---
import { defaultLanguage, useTranslations, type LanguageCode } from '@/i18n/ui';

const lang =
  (Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
const tFooter = useTranslations(lang, 'footer');
const tSite = useTranslations(lang, 'site');
---

<footer class="relative mt-auto py-8 z-10 border-t border-border">
  <div class="container mx-auto px-6 max-w-screen-xl">
    <p class="text-center text-xs text-muted-foreground uppercase tracking-widest" style="font-family: var(--font-heading);">
      &copy; {new Date().getFullYear()}
      <span class="font-medium text-foreground"> {tSite('title')}</span>. {tFooter('rights')}
    </p>
  </div>
</footer>
