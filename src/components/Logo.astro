---
import { defaultLanguage, type LanguageCode } from '@/i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';
const currentLocale =
  (Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
---

<a href={getRelativeLocaleUrl(currentLocale)} class="group flex items-center gap-2">
  <span class="text-xl font-bold text-primary tracking-tight" style="font-family: var(--font-heading);">
    ahmdsaif
  </span>
  <span class="relative flex h-2 w-2">
    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
    <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
  </span>
</a>
