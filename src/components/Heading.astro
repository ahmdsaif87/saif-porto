---
import { cn } from '@/lib/utils';

interface Props {
  title: string;
  description?: string;
  className?: string;
  titleClassName?: string;
  descriptionClassName?: string;
  showDivider?: boolean;
}

const {
  title,
  description,
  className,
  titleClassName,
  descriptionClassName,
  showDivider = false,
} = Astro.props;
---

<div class={cn('mb-10 space-y-4', className)}>
  <h1
    class={cn('text-3xl font-bold tracking-tight sm:text-4xl', titleClassName)}
    style="font-family: var(--font-heading);"
  >
    {title}
  </h1>
  {showDivider && <div class="gradient-divider max-w-48 mx-auto"></div>}
  {
    description ? (
      <p class={cn('max-w-3xl text-muted-foreground text-lg leading-relaxed', descriptionClassName)}>
        {description}
      </p>
    ) : null
  }
</div>
