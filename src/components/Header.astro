---
import { defaultLanguage, type LanguageCode } from '../i18n/ui';
import type { NavItem } from '@/layouts/BaseLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
  navItems: Array<NavItem>;
}
const { navItems } = Astro.props as Props;

const currentLocale =
  (Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full border-b bg-background border-border transition-all duration-300"
>
  <nav class="mx-auto px-6 max-w-screen-xl h-16 flex justify-between items-center">
    <Logo />

    {/* Desktop navigation */}
    <div class="hidden md:flex items-center gap-x-1">
      {
        navItems.map((link) => {
          const href = getRelativeLocaleUrl(currentLocale, link.href);
          const isActive = currentPath === href || (link.href !== '/' && currentPath.startsWith(href));
          return (
            <a
              href={href}
              class:list={[
                'relative px-4 py-2 text-sm font-medium rounded-lg transition-all duration-300',
                isActive
                  ? 'text-foreground bg-accent'
                  : 'text-muted-foreground hover:text-foreground hover:bg-muted/50',
              ]}
            >
              {link.label}
              {isActive && (
                <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-6 h-0.5 rounded-full bg-primary" />
              )}
            </a>
          );
        })
      }
    </div>

    <div class="flex items-center gap-x-2">
      <ThemeToggle />
      <MobileMenu navItems={navItems} />
    </div>
  </nav>
</header>
