---
import { defaultLanguage, type LanguageCode } from '../i18n/ui';
import type { NavItem } from '@/layouts/BaseLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
import MobileMenu from './MobileMenu.astro';

interface Props {
  navItems: Array<NavItem>;
  isLandingPage?: boolean;
}
const { navItems, isLandingPage = false } = Astro.props as Props;

const currentLocale =
  (Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm transition-all duration-300"
>
  <nav class="mx-auto px-6 max-w-screen-xl h-16 flex justify-between items-center">
    <Logo />

    {/* Desktop navigation */}
    <div class="hidden md:flex items-center gap-x-1">
      {
        navItems.map((link) => {
          const isAnchor = link.href.startsWith('#');
          const href = isAnchor ? link.href : getRelativeLocaleUrl(currentLocale, link.href);
          const isActive = !isAnchor && (currentPath === href || (link.href !== '/' && currentPath.startsWith(href)));
          return (
            <a
              href={href}
              class:list={[
                'relative px-4 py-2 text-xs font-medium uppercase tracking-widest transition-all duration-300',
                isActive
                  ? 'text-foreground'
                  : 'text-muted-foreground hover:text-foreground',
              ]}
              style={`font-family: var(--font-heading);`}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>

    <div class="flex items-center gap-x-2">
      <ThemeToggle />
      <MobileMenu navItems={navItems} />
    </div>
  </nav>
</header>
